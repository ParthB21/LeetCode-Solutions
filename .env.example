# Copy this file to ".env" and fill in the values.
#
# How to get these (Chrome/Edge/Firefox):
#   1. Log in to https://leetcode.com
#   2. Open DevTools (F12) -> Application/Storage -> Cookies -> https://leetcode.com
#   3. Copy the values of the two cookies below.
#
# Treat these like passwords. They grant access to your LeetCode account.

LEETCODE_SESSION=paste_leetcode_session_cookie_here
LEETCODE_CSRFTOKEN=paste_csrftoken_cookie_here

# Optional: LeetCode domain (use leetcode.cn if you're on the China site)
LEETCODE_DOMAIN=leetcode.com

# Optional: where solutions get written (defaults to ./solutions)
SOLUTIONS_DIR=solutions
